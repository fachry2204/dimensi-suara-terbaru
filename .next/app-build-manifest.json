      "static/chunks/main-app.js",
      "static/chunks/app/api/genres/route.js"
    ],
    "/api/settings/branding/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/settings/branding/route.js"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/_not-found/page.js"
    ],
